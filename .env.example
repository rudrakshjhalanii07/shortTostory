# ─────────────────────────────────────────────────────────────────────────────
# ShortStory configuration. Copy to `.env` and fill in. NEVER commit `.env`.
# Every value the app reads MUST be declared here (no hardcoded config in code).
# ─────────────────────────────────────────────────────────────────────────────

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- HTTP server (Phase 6) ---
PORT=3000
# Public base URL the mobile app targets; also used to build deep links.
PUBLIC_BASE_URL=http://localhost:3000

# --- Redis / BullMQ (Phase 3) ---
REDIS_URL=redis://localhost:6379
JOB_QUEUE_NAME=shortstory:cards
# How long completed/failed job records linger in Redis (seconds).
JOB_RETENTION_SECONDS=3600

# --- YouTube Data API v3 (Phase 4) ---
# Official API key. Metadata + thumbnails only — we never download the video.
YOUTUBE_API_KEY=
# Reject Shorts longer than this (seconds). Product hard limit is 90.
MAX_VIDEO_DURATION_SECONDS=90

# --- ffmpeg (Phase 5) ---
FFMPEG_PATH=ffmpeg
# Output card dimensions (Instagram Story is 1080x1920, 9:16).
CARD_WIDTH=1080
CARD_HEIGHT=1920

# --- S3-compatible storage (Phase 5/10) ---
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=shortstory-cards
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# TTL for signed download URLs handed to the device (seconds).
DOWNLOAD_URL_TTL_SECONDS=900

# --- Rate limiting (Phase 6) ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=10
