{
  "name": "shortstory",
  "version": "0.1.0",
  "private": true,
  "description": "Share YouTube Shorts to Instagram Stories with creator attribution baked in (compliant Model B: attribution cards, no video redistribution).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/backend",
    "apps/mobile",
    "apps/web"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace @shortstory/shared",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
