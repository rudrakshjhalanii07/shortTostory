# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000                     # HTTP listen port

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                # debug | info | warn | error

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all (dev only).
CORS_ORIGINS=*

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000    # Window size in milliseconds (default: 60s)
RATE_LIMIT_MAX=30             # Max requests per window per IP

# ─── Queue mode ───────────────────────────────────────────────────────────────
# 'inline'  — process jobs in-process, no Redis/BullMQ required (personal/dev use).
# 'bullmq'  — enqueue jobs into BullMQ backed by Redis (production).
# Default: 'bullmq' when REDIS_URL is set, 'inline' otherwise.
# QUEUE_MODE=inline

# ─── Redis (required when QUEUE_MODE=bullmq) ──────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── YouTube Data API v3 (Phase 4) ────────────────────────────────────────────
# Obtain at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# ─── Public URL (required in production when S3 is not configured) ────────────
# Set to your Railway-generated domain, e.g. https://your-app.up.railway.app
# PUBLIC_URL=

# ─── S3-compatible storage (Phase 5/6) ────────────────────────────────────────
S3_BUCKET=shortstory-cards
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Leave blank for AWS; set for MinIO / R2 / Backblaze etc.
S3_ENDPOINT=

# Signed URL TTL in seconds (default: 1 hour)
SIGNED_URL_TTL_SECONDS=3600
